Package: storeAnalysis
Type: Package
Title: Analiza i Prognozowanie Szeregów Czasowych Sprzedaży Detalicznej
Version: 0.1.0
Authors@R: c(
    person("Jaroslaw", "Lesny", email = "jlesny@student.uw.edu.pl", role = c("aut", "cre")),
